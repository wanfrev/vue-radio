# --- Server ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# --- CORS ---
# Comma-separated list of allowed origins. Use "*" only in dev.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Stream (public) ---
# The HTTPS URL your <audio> element will play. Must be reachable from the browser.
STREAM_URL=https://your-radio.example.com/stream.mp3
STREAM_NAME=My Radio

# --- AutoDJ / source of truth ---
# URL of your AutoDJ's "now playing" endpoint (e.g. Azuracast, Icecast JSON, Liquidsoap, custom).
# If left blank or unreachable, the backend falls back to a deterministic MOCK so you can
# develop without infra.
AUTODJ_API_URL=
AUTODJ_API_KEY=
AUTODJ_POLL_INTERVAL_MS=5000

# --- iTunes cover art (fallback when AutoDJ does not return art) ---
ITUNES_API_URL=https://itunes.apple.com/search
ITUNES_CACHE_TTL_MS=86400000

# --- Rate limiting ---
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# --- History ---
HISTORY_MAX_ITEMS=20

# --- SQLite ---
DATABASE_PATH=./data/radio.db

# --- Admin auth ---
# Generate a password hash: node -e "console.log(require('bcrypt').hashSync('YOUR_PASSWORD', 12))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=<bcrypt hash here>
# Generate secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<at least 32 random hex chars>
COOKIE_SECRET=<at least 16 random hex chars>

# --- Azuracast (optional — enables /api/admin/live/*) ---
# AZURACAST_BASE_URL=https://azuracast.your-server.com
# AZURACAST_API_KEY=<admin-api-key>
# AZURACAST_STATION_ID=1
# AZURACAST_LIVE_DJ_MOUNTPOINT=/stream_live
# AZURACAST_LIVE_DJ_PASSWORD=<dj-mountpoint-password>
